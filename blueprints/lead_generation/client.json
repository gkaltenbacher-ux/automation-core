{
  "version": "2.0",
  "company_name": "KUNDENNAME",
  "language": "de",
  "dashboard_title": "Lead-System",
  "dashboard_logo_url": "",

  "credential_types": {
    "openai_api": {
      "name": "OpenAI API",
      "description": "API Key fuer GPT Models + Orchestrator",
      "fields": [
        {"name": "api_key", "label": "API Key", "type": "password", "required": true, "placeholder": "sk-..."}
      ],
      "test_fn": "openai"
    },
    "apify_api": {
      "name": "Apify API",
      "description": "API Token fuer Web Scraping (Google Maps, LinkedIn, E-Mails)",
      "fields": [
        {"name": "api_token", "label": "API Token", "type": "password", "required": true, "placeholder": "apify_api_..."}
      ],
      "test_fn": "apify"
    },
    "notion_api": {
      "name": "Notion API",
      "description": "Integration Token + Database ID fuer CRM",
      "fields": [
        {"name": "api_key", "label": "Integration Token", "type": "password", "required": true, "placeholder": "ntn_..."},
        {"name": "database_id", "label": "Database ID", "type": "text", "required": true, "placeholder": "abc123..."}
      ],
      "test_fn": "notion"
    },
    "gmail": {
      "name": "Gmail",
      "description": "E-Mail-Versand via Gmail App-Password",
      "fields": [
        {"name": "email", "label": "Gmail E-Mail-Adresse", "type": "text", "required": true},
        {"name": "app_password", "label": "App-Password", "type": "password", "required": true, "placeholder": "xxxx xxxx xxxx xxxx"}
      ],
      "test_fn": "gmail"
    },
    "telegram_bot": {
      "name": "Telegram Bot",
      "description": "Bot Token fuer Telegram-Steuerung",
      "fields": [
        {"name": "bot_token", "label": "Bot Token", "type": "password", "required": true},
        {"name": "allowed_user_ids", "label": "Erlaubte User-IDs (kommagetrennt)", "type": "text", "required": false}
      ],
      "test_fn": "telegram"
    }
  },

  "key_mapping": {
    "openai": {"credential_type": "openai_api", "field": "api_key"},
    "apify": {"credential_type": "apify_api", "field": "api_token"},
    "notion": {"credential_type": "notion_api", "field": "api_key"},
    "notion_database_id": {"credential_type": "notion_api", "field": "database_id"},
    "gmail_email": {"credential_type": "gmail", "field": "email"},
    "gmail_app_password": {"credential_type": "gmail", "field": "app_password"}
  },

  "agents": {
    "lead_researcher": {
      "enabled": true,
      "tools": ["scrape_google_maps", "scrape_linkedin", "extract_emails", "score_leads", "generate_lead_id", "check_duplicate"],
      "model": "gpt-4o-mini",
      "system_prompt": "Du bist ein Lead-Researcher. Deine Aufgabe: Leads finden, E-Mails extrahieren, bewerten und im CRM speichern. Antworte auf Deutsch, kurz und praezise."
    },
    "outreach_agent": {
      "enabled": true,
      "tools": ["generate_text", "send_gmail"],
      "model": "gpt-4o-mini",
      "system_prompt": "Du bist ein Outreach-Agent. Deine Aufgabe: Personalisierte E-Mails generieren und versenden. NIEMALS ohne explizite Bestaetigung senden! Antworte auf Deutsch."
    },
    "crm_agent": {
      "enabled": true,
      "tools": ["sync_notion", "check_duplicate"],
      "model": "gpt-4o-mini",
      "system_prompt": "Du bist ein CRM-Agent. Deine Aufgabe: Lead-Daten im Notion CRM verwalten, Duplikate pruefen, Status aktualisieren. Antworte auf Deutsch."
    }
  },

  "orchestrator": {
    "enabled": true,
    "model": "gpt-4o-mini",
    "system_prompt": "Du bist der Lead-System Assistent. Du hilfst beim Finden, Bewerten und Kontaktieren von Leads. Antworte auf Deutsch, informell, kurz. E-Mails NIEMALS ohne Bestaetigung senden!"
  },

  "telegram": {
    "enabled": true,
    "start_text": "Ich bin dein Lead-System Bot.\n\nIch kann:\n- Leads scrapen (Google Maps / LinkedIn)\n- Leads bewerten\n- E-Mails generieren\n- CRM-Stats zeigen\n\nSchreib mir was du brauchst!",
    "help_text": "*Lead-System Bot Hilfe*\n\nBeispiele:\n- \"Scrape 20 Agenturen aus Zuerich\"\n- \"Wie viele Leads haben wir?\"\n- \"Generiere E-Mails fuer Top 5 Leads\"",
    "commands": [
      {"command": "stats", "description": "CRM Statistiken", "message": "Zeig mir die CRM-Statistiken"}
    ]
  },

  "workflows": [
    {
      "name": "Lead-Scraping",
      "description": "Scrapt Leads, bewertet sie und speichert im CRM",
      "steps": [
        {"type": "agent", "agent": "lead_researcher", "task": "Finde und bewerte neue Leads", "data_key": "leads"},
        {"type": "pause", "message": "Leads gefunden. E-Mails generieren?"},
        {"type": "agent", "agent": "outreach_agent", "task": "Generiere personalisierte E-Mails", "data_key": "emails"},
        {"type": "pause", "message": "E-Mails generiert. Versenden?"},
        {"type": "agent", "agent": "outreach_agent", "task": "Versende die generierten E-Mails"}
      ]
    }
  ],

  "dsgvo": {
    "enabled": true,
    "data_categories": ["lead_data", "email_content", "crm_entry"],
    "consent_types": ["legitimate_interest"]
  },

  "automations": [],
  "api_keys_needed": []
}
